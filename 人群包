drop table if exists temp.temp_app_ads_spu_group_metrics_detail_30d_df_{{ds_nodash}};

create table
  if not exists temp.temp_app_ads_spu_group_metrics_detail_30d_df_{{ds_nodash}} as
select
  group_id,
  spu_id,
  group_name,
  dt,
  dt_detail
from 
(select group_id,spu_id,max(group_name) as group_name
from `redapp`.`app_ads_aurora_creativity_user_group_metrics_1d_di` 
where dtm>='20240101'
group by 1,2
)a
left join 
  (select t1.dt ,t2.dt as dt_detail
  from 
    (select dt 
    from redcdm.dim_ads_date_df 
    where dtm='all' and dt>='2024-06-01' and dt<='{{ds}}'
    )t1 
    left join 
    (select dt
    from redcdm.dim_ads_date_df 
    where dtm='all' and dt>='2023-06-01' and dt<='{{ds}}'
    )t2 
    on t2.dt>=date_add(t1.dt,-29) and t2.dt<=t1.dt
  )t2 
  on 1 = 1;
select dt as date_key,
t1.group_id
t1.spu_id,
t1.group_name,
  spu.spu_name,
  spu.commercial_name,
  sum(fee) as fee,
  sum(imp_num) as imp_num,
  sum(click_num) as click_num,
  sum(engage_num) as engage_num,
  sum(new_i_people_num) as new_i_people_num,
  sum(new_ti_people_num) as new_ti_people_num,
  sum(outside_seller_pv/(50/100)) as outside_seller_pv_convet,
  sum(tb_task_click_num) as tb_task_click_num,
sum(tb_task_fee) as tb_task_fee
from 
temp.temp_app_ads_spu_group_metrics_detail_30d_df_{{ds_nodash}} t1 
left join 

(select 
  f_getdate(attri_date) as date_key,
  group_id, 
  spu_id,
  max(spu_name) as spu_name,
  max(group_name) as group_name,
  sum(fee) as fee,
  sum(imp_num) as imp_num,
  sum(click_num) as click_num,
  sum(engage_num) as engage_num,
  sum(new_i_people_num) as new_i_people_num,
  sum(new_ti_people_num) as new_ti_people_num,
  sum(outside_seller_pv/(50/100)) as outside_seller_pv_convet,
  sum(tb_task_click_num) as tb_task_click_num,
sum(tb_task_fee) as tb_task_fee
  
from
  redapp.app_ads_aurora_creativity_user_group_metrics_1d_di
  where dtm>='20240101' and dtm<='{{ds_nodash}}'
  group by 1,2,3
)detail 
on detail.spu_id = t1.spu_id and t1.dt_detail=detail.date_key and detail.group_id = t1.group_id
left join 
(select spu_id,
  name as spu_name,
 
  commercial_name,
  
  commercial_level
from ads_databank.dim_spu_df
where  dtm='{{ds_nodash}}' 

)spu
on spu.spu_id = t1.spu_id
group by dt ,
t1.group_id
t1.spu_id,
t1.group_name,
  spu.spu_name,
  spu.commercial_name
