SELECT
  date_key,
  SUM(case when module = '品合' then cash_cost else 0 end) AS bcoo_cash_cost,
  SUM(case when module = '品合' then cost else 0 end) AS bcoo_cost,
  SUM(case when module = '品牌' then cash_cost else 0 end) AS brand_cash_cost,
  SUM(case when module = '品牌' then cost else 0  end) AS brand_cost,
  SUM(case when module = '薯条' then cash_cost else 0 end ) AS chips_cash_cost,
  SUM(case when module = '薯条' then cost  else 0 end  ) AS chips_cost,
  SUM(case when module = '效果' then cash_cost else 0 end) AS rtb_cash_cost,
  SUM(case when module = '效果' then cost  else 0 end) AS rtb_cost,
  SUM(mkt_ecm_cost) AS mkt_ecm_cost,
  SUM(mkt_leads_cost) AS mkt_leads_cost,
  SUM(mkt_zc_cost) as mkt_ti_cost,
  SUM(mkt_ecm_cash_cost) as mkt_ecm_cash_cost,
  SUM(mkt_leads_cash_cost) as mkt_leads_cash_cost,
  SUM(mkt_zc_cash_cost) as mkt_ti_cash_cost,
  SUM(mkt_ecm_unclosed_cost) as mkt_ecm_unclosed_cost,
  SUM(mkt_ecm_unclosed_cash_cost) as mkt_ecm_unclosed_cash_cost
FROM
  redcdm.dm_ads_industry_product_account_td_df
WHERE
  dtm = '20230525'
  and module <> 'IP'
GROUP BY
  date_key